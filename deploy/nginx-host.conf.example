# Copiar a: /etc/nginx/sites-available/quoter.balamst.com
# Luego: sudo ln -s /etc/nginx/sites-available/quoter.balamst.com /etc/nginx/sites-enabled/
#
# Antes de certbot, usar solo el bloque HTTP (listen 80).
# Certbot añadirá SSL y redirección HTTPS automáticamente.
#
# IMPORTANTE: /api/ va directo al contenedor API (puerto 8082 en el host).
# El frontend va al contenedor nginx (puerto 8081).

server {
    listen 80;
    listen [::]:80;
    server_name quoter.balamst.com;

    location /api/ {
        proxy_pass http://127.0.0.1:8082/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://127.0.0.1:8081;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
